# Telegram connection. Real values belong only in .env on the machine/VPS.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION_PATH=data/promo_publisher

# Safe local defaults. The Saved Messages config may override these values.
PUBLICATION_ENABLED=false
PUBLICATION_DELAY_MIN_SECONDS=15
PUBLICATION_DELAY_MAX_SECONDS=30
PUBLICATION_INTERVAL_MIN_MINUTES=60
PUBLICATION_INTERVAL_MAX_MINUTES=90
TELEGRAM_FOLDER_NAME=Реклама
PROMO_BOT_USERNAME=@your_bot_username

# Remote runtime configuration in Telegram Saved Messages.
REMOTE_CONFIG_ENABLED=true
REMOTE_CONFIG_MARKER=promo-publisher-config
REMOTE_CONFIG_REQUIRED=true
REMOTE_CONFIG_POLL_SECONDS=5
