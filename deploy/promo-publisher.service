[Unit]
Description=Promo Publisher Telegram client
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=promo-publisher
Group=promo-publisher
WorkingDirectory=/opt/promo-publisher
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/promo-publisher/.local/bin/uv run python -m app.main --daemon
Restart=always
RestartSec=10
KillSignal=SIGINT
TimeoutStopSec=30
UMask=0077
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
